# ---------------------------------------------------------
# [1] Worker 쓰레드: ROS 데이터를 수신하여 GUI로 전달
# ---------------------------------------------------------
class RosWorker(QThread):
    battery_signal = Signal(float)
    pose_signal = Signal(float, float)

    def run(self):
        """가제보나 실제 로봇이 없어도 테스트 가능하도록 가상 데이터 생성"""
        while True:
            # 1. 가상 배터리 데이터 (80%~100% 사이 랜덤)
            fake_battery = random.uniform(10, 100)
            self.battery_signal.emit(fake_battery)
            self.msleep(1000) # 1초 간격 업데이트

# ---------------------------------------------------------
# [1-2] Camera Worker 쓰레드: 카메라 영상을 수신하여 GUI로 전달
# ---------------------------------------------------------
class CameraWorker(QThread):
    frame_signal = Signal(QImage)

    def run(self):
        cap = cv2.VideoCapture(0) #이 부분은 나중에 ROS2 토픽 수신으로 변경해야 함
        while True:
            ret, frame = cap.read()
            if ret:
                rgb_image = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
                h, w, ch = rgb_image.shape
                bytes_per_line = ch * w
                qt_image = QImage(rgb_image.data, w, h, bytes_per_line, QImage.Format_RGB888)
                scaled_image = qt_image.scaled(400, 300, Qt.KeepAspectRatio)
                self.frame_signal.emit(scaled_image)
            self.msleep(30)

