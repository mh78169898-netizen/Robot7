if __name__ == '__main__':
    app = QApplication(sys.argv)
    window = RobotDashboard()
    window.show()
    sys.exit(app.exec())
---------------------------------------실제 터틀봇과의 연동 버전----------------------------------------------------------
import sys
import math
import time
import random
import os #추가한 부분
import cv2 #카메라 영상을 위해 추가
import numpy as np #영상 데이터 처리
from cv_bridge import CvBridge #OpenCV에서 카메라 영상 처리를 위해 필요
# ROS2 관련 추가
import rclpy
from rclpy.node import Node
from sensor_msgs.msg import BatteryState, Image
from nav_msgs.msg import Odometry
from geometry_msgs.msg import Twist

from PySide6.QtWidgets import *
from PySide6.QtCore import *
from PySide6.QtGui import *

# 1. UI 파일 (teamtest.py로 변환되었다고 가정)
# 만약 파일명이 다르면 그에 맞게 수정하세요.
from my_team_test2.teamtest_ui import Ui_Form

# ---------------------------------------------------------
# [1] Worker 쓰레드: ROS 데이터를 수신하여 GUI로 전달
# ---------------------------------------------------------
class RosWorker(QThread):
    battery_signal = Signal(float)
    pose_signal = Signal(float, float)
    camera_signal = Signal(QImage) #카메라 신호 추가

    def __init__(self):
        super().__init__()
        if not rclpy.ok():rclpy.init()
        self.node = Node('gui_subscriber_node')
        self.bridge = CvBridge()
        self.battery_sub = self.node.create_subscription(BatteryState,'/battery_state', self.battery_callback,10) #배터리 구독(실제 터틀봇)
        self.odom_sub = self.node.create_subscription(Odometry, '/odom', self.odom_callback, 10) #위치 구독 코드(실제 터틀봇)
        self.image_sub = self.node.create_subscription(Image, '/camera/image_raw', self.image_callback, 10)

        self.cmd_vel_pub = self.node.create_publisher(Twist, 'cmd/vel', 10) #발행자 설정

    def battery_callback(self, msg):
        """실제 배터리 데이터가 들어오면 실행되는 함수"""
        battery_percent = msg.percentage
        self.battery_signal.emit(battery_percent)

    def odom_callback(self, msg):
        """실제 로봇 위치 데이터가 들어오면 실행되는 함수"""
        curr_x = msg.pose.pose.position.x
        curr_y = msg.pose.pose.position.y
        self.pose_signal.emit(curr_x, curr_y)

    def image_callback(self, msg):
        try:
            cv_img = self.bridge.imgmsg_to_cv2(msg, desired_encoding='bgr8')
            rgb_img = cv2.cvtColor(cv_img, cv2.COLOR_BGR2RGB)
            h,w,ch = rgb_img.shape
            bytes_per_line = ch * w
            qt_image = QImage(rgb_img.data,w,h,bytes_per_line,QImage.Format_RGB888)
            self.camera_signal.emit(qt_image.copy())
        except Exception as e:
            print(f"이미지 변환 실패: {e}")

    def publish_twist(self, linear_v, anguler_w):
        msg = Twist()
        msg.linear.x = float(linear_v)
        msg.angular.z = float(anguler_w)
        self.cmd_vel_pub.publish(msg)

    def run(self):
        """쓰레드가 시작되면 ROS 2 이벤트를 계속 체크합니다."""
        while rclpy.ok():
            # 0.1초 간격으로 새로운 토픽 데이터가 있는지 검사
            rclpy.spin_once(self.node, timeout_sec=0.1)

    def stop(self):
        self.node.destroy_node()
        rclpy.shutdown()
